// Copy to `insomnia.baml` and fill in prompts (see resources/Insomnia_Rules.md). Not used at runtime until renamed.

class SleepDifficultyEvidence {
  citation string @description("Verbatim substring from the note supporting Definition 1 criteria")
}

class DaytimeImpairmentEvidence {
  citation string @description("Verbatim substring from the note supporting Definition 2 criteria")
}

class MedicationEvidence {
  med_type "primary" | "secondary" @description("Primary insomnia medication (Rule B) or secondary medication (Rule C)")
  citation string @description("Verbatim substring from the note for this medication mention")
}

class ClinicalNoteExtraction {
  sleep_difficulty SleepDifficultyEvidence[] @description("All extracted Definition 1 evidence items")
  daytime_impairment DaytimeImpairmentEvidence[] @description("All extracted Definition 2 evidence items")
  medications MedicationEvidence[] @description("All extracted medication mentions used for Rule B/C")
}

function ExtractClinicalEvidence(note_text: string, few_shot_context: string) -> ClinicalNoteExtraction {
  client CustomGemini
  prompt #"
    {{ _.role("system") }}
    Replace this block with your extraction instructions for:
    - Definition 1 evidence (sleep difficulty),
    - Definition 2 evidence (daytime impairment),
    - medication evidence with med_type primary/secondary.
    Enforce verbatim citations copied directly from the note.

    {{ _.role("user") }}
    Few-shot examples (may be empty):
    {{ few_shot_context }}

    Clinical note:
    {{ note_text }}

    {{ ctx.output_format }}
  "#
}
