// ============================================================
// insomnia_v1.baml.bak — DEPRECATED single-pass functions
//
// Preserved for A/B comparison with the v2 two-pass architecture.
// This file is NOT parsed by the BAML compiler (.bak extension).
//
// To restore and use these:
//   1. Copy content back into insomnia.baml (replacing v2 schema)
//   2. Run: baml generate
//   3. Run inference with: insomnia-inference --pipeline v1
// ============================================================

class InsomniaBinary {
  insomnia "yes" | "no" @description("Whether the patient has insomnia per Rule A, Rule B, or Rule C in the task instructions")
}

class RuleEvidence {
  label "yes" | "no"
  evidence_quotes string[] @description("Verbatim substrings copied from the note that support the label; use empty list when label is no")
}

class InsomniaEvidenceExtraction {
  definition_1 RuleEvidence @description("Definition 1: Difficulty Sleeping")
  definition_2 RuleEvidence @description("Definition 2: Daytime Impairment")
  rule_b RuleEvidence @description("Rule B: primary insomnia medications")
  rule_c RuleEvidence @description("Rule C: secondary insomnia medications with Definition 1 or 2 symptoms")
}

function ClassifyInsomnia(note_text: string) -> InsomniaBinary {
  client CustomGemini
  prompt #"
    {{ _.role("system") }}
    You classify clinical notes for the insomnia detection shared task.

    Use these definitions and rules exactly:

    **Definition 1: Difficulty Sleeping**
    The patient is considered to have difficulty sleeping if they report any of the following:
    1. Trouble initiating sleep.
    2. Trouble maintaining sleep.
    3. Waking up earlier than desired.
    4. An explicit mention of insomnia.

    **Definition 2: Daytime Impairment**
    The patient is considered to have daytime impairment if they report any of the following:
    1. Fatigue or malaise.
    2. Impaired attention, concentration, or memory.
    3. Impaired social, family, occupational, or academic performance.
    4. Mood disturbance or irritability.
    5. Daytime sleepiness.
    6. Behavioral problems such as hyperactivity, impulsivity, or aggression.
    7. Decreased motivation, energy, or initiative.
    8. Proneness to errors or accidents.
    9. Concerns or dissatisfaction with sleep.
    10. An explicit mention of insomnia.

    **Rule A:** The patient is considered to have insomnia if they meet both Definition 1 (difficulty sleeping) and Definition 2 (daytime impairment).

    **Rule B:** The patient has insomnia if prescribed any of the following primary insomnia medications (including brand names): Estazolam, Eszopiclone (Lunesta), Flurazepam (Dalmane), Lemborexant (Dayvigo), Quazepam (Doral), Ramelteon (Rozerem), Suvorexant (Belsomra), Temazepam (Restoril), Triazolam (Halcion), Zaleplon (Sonata), Zolpidem (Ambien).

    **Rule C:** The patient has insomnia if prescribed any of the following secondary insomnia medications AND reports any symptoms from Definition 1 or Definition 2: Acamprosate (Campral), Alprazolam (Xanax), Clonazepam (Klonopin), Clonidine (Catapres), Diazepam (Valium), Diphenhydramine (Benadryl), Doxepin (Silenor), Gabapentin (Neurontin), Hydroxyzine (Vistaril/Atarax), Lorazepam (Ativan), Melatonin, Mirtazapine (Remeron), Olanzapine (Zyprexa), Quetiapine (Seroquel), Trazodone (Desyrel).

    **SPECIAL CASES AND EXCLUSIONS:**
    - Difficulty sleeping caused by other conditions (pain, discomfort, being uncomfortable) should NOT automatically count toward insomnia.
      Examples to EXCLUDE: "trouble sleeping due to being uncomfortable", "inability to sleep because pain relief is inadequate"
    - For overnight nursing shifts: daytime impairment symptoms should generally NOT be counted, as they may reflect normal nighttime behavior.
      EXCEPTIONS that still count overnight: concerns/dissatisfaction with sleep, and explicit mentions of "insomnia".

    **Insomnia status:** The patient is considered to have insomnia if they meet the criteria of Rule A, Rule B, or Rule C ("yes"). If none of these rules are met, label "no".

    {{ _.role("user") }}
    Clinical note:
    {{ note_text }}

    {{ ctx.output_format }}
  "#
}

function ExtractInsomniaEvidence(note_text: string) -> InsomniaEvidenceExtraction {
  client CustomGemini
  prompt #"
    {{ _.role("system") }}
    You extract evidence for insomnia sub-definitions from a clinical note.

    For each of the four blocks below, set label to "yes" or "no" and provide supporting evidence quotes.

    ## DEFINITIONS

    **Definition 1: Difficulty Sleeping**
    Label "yes" if the note reports ANY of:
    1. Trouble initiating sleep
    2. Trouble maintaining sleep
    3. Waking earlier than desired
    4. An explicit mention of "insomnia"

    Example evidence spans: "difficulty falling asleep", "unable to sleep", "sleeplessness", "insomnia", "was having difficulty falling asleep", "Pt verbalizing unable to sleep most of noc"

    **Definition 2: Daytime Impairment**
    Label "yes" if the note reports ANY of:
    1. Fatigue or malaise
    2. Impaired attention, concentration, or memory
    3. Impaired social, family, occupational, or academic performance
    4. Mood disturbance or irritability
    5. Daytime sleepiness
    6. Behavioral problems (hyperactivity, impulsivity, aggression)
    7. Decreased motivation, energy, or initiative
    8. Proneness to errors or accidents
    9. Concerns or dissatisfaction with sleep
    10. An explicit mention of "insomnia"

    Example evidence spans: "lethargic", "difficulty concentrating", "fatigue", "very upset about his condition", "has had primary symptoms of fatigue"

    ## MEDICATION RULES

    **Rule B: Primary Insomnia Medications**
    Label "yes" if ANY of these medications are prescribed (including brand names and misspellings):
    Estazolam, Eszopiclone (Lunesta), Flurazepam (Dalmane), Lemborexant (Dayvigo), Quazepam (Doral), Ramelteon (Rozerem), Suvorexant (Belsomra), Temazepam (Restoril), Triazolam (Halcion), Zaleplon (Sonata), Zolpidem (Ambien)

    **Rule C: Secondary Insomnia Medications + Symptoms**
    Label "yes" if BOTH conditions are met:
    - ANY of these medications are prescribed: Acamprosate, Alprazolam (Xanax), Clonazepam (Klonopin), Clonidine (Catapres), Diazepam (Valium), Diphenhydramine (Benadryl), Doxepin (Silenor), Gabapentin (Neurontin), Hydroxyzine (Vistaril/Atarax), Lorazepam (Ativan), Melatonin, Mirtazapine (Remeron), Olanzapine (Zyprexa), Quetiapine (Seroquel), Trazodone (Desyrel)
    - AND any symptom from Definition 1 OR Definition 2 is present

    For Rule C evidence_quotes: include BOTH the medication mention AND the symptom evidence.

    ## EVIDENCE SPAN GUIDELINES

    - Copy verbatim substrings exactly as they appear in the note
    - Select the SMALLEST text span that contains complete meaning
    - Avoid including punctuation unless necessary for meaning
    - Include important modifiers (temporal cues like "recently", "last night"; negations; context words)
    - For patient quotes: extract WITHOUT quotation marks (e.g., extract "IVE SLEPT 3HRS IN 5 DAYS" not the surrounding quotes)
    - Recognize medication misspellings and variant forms (e.g., "clozepam" for clonazepam, "Zyprexia" for Zyprexa)
    - Drug mentions for Rule B or Rule C should NOT be duplicated as evidence for Definition 1/2
    - EXCEPTION: If a medication NOT in Rules B/C is explicitly linked to sleep symptoms, it CAN support Definition 1/2 (e.g., "Serax for sleep")

    ## EXCLUSIONS

    - Difficulty sleeping from other conditions (pain, discomfort) does NOT count toward Definition 1
      Examples to EXCLUDE: "trouble sleeping due to being uncomfortable", "inability to sleep because pain relief is inadequate"
    - For overnight nursing shifts: daytime impairment symptoms generally do NOT count
      EXCEPTIONS that still count: concerns/dissatisfaction with sleep, explicit "insomnia" mentions

    ## OUTPUT

    For each block (definition_1, definition_2, rule_b, rule_c):
    - label: "yes" or "no"
    - evidence_quotes: array of verbatim text spans from the note (empty array [] if label is "no")

    {{ _.role("user") }}
    Clinical note:
    {{ note_text }}

    {{ ctx.output_format }}
  "#
}
